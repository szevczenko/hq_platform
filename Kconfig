mainmenu "hq_platform"

menu "Platform Selection"

choice
  prompt "Target platform"
  default HQ_PLATFORM_POSIX
  help
    Select the target platform for this build

config HQ_PLATFORM_POSIX
  bool "POSIX (Linux/Windows/macOS)"
  help
    Build for POSIX-compatible systems

config HQ_PLATFORM_ESP
  bool "ESP32 (ESP-IDF)"
  help
    Build for ESP32 microcontroller

config HQ_PLATFORM_STM32
  bool "STM32 (ARM Cortex-M)"
  depends on BROKEN
  help
    Build for STM32 microcontroller family

config HQ_PLATFORM_NXP
  bool "NXP (i.MX/MCUX)"
  depends on BROKEN
  help
    Build for NXP i.MX or MCUX platforms

endchoice

endmenu

menu "OSAL"

config OSAL_LOG_LEVEL
  int "OSAL log level"
  default 3
  range 0 3
  help
    0 = DEBUG
    1 = INFO
    2 = WARNING
    3 = ERROR

endmenu

menu "Command Line"

choice
  prompt "ESP32 CMD output interface"
  depends on HQ_PLATFORM_ESP
  default CMD_ESP_OUTPUT_CONSOLE

config CMD_ESP_OUTPUT_CONSOLE
  bool "Use ESP-IDF console (stdout)"
  help
    CMD output goes through putchar()/stdout.
    Requires ESP-IDF console UART to be configured in menuconfig:
      Component Config -> ESP System Settings -> Console Output
        CONFIG_ESP_CONSOLE_UART_DEFAULT=y
        CONFIG_ESP_CONSOLE_UART_NUM=<port>
        CONFIG_ESP_CONSOLE_UART_BAUDRATE=<baud>

config CMD_ESP_OUTPUT_UART
  bool "Use direct UART driver"
  help
    CMD output goes directly to a UART peripheral.
    Does not use or conflict with the ESP-IDF console.
    Output only, no input handling.

endchoice

config CMD_ESP_UART_NUM
  int "UART port number"
  depends on CMD_ESP_OUTPUT_UART
  default 1
  range 0 2
  help
    UART peripheral for CMD output (0, 1, or 2).
    Avoid the port used by ESP-IDF console (usually 0).

config CMD_ESP_UART_BAUDRATE
  int "UART baudrate"
  depends on CMD_ESP_OUTPUT_UART
  default 115200
  help
    Baudrate for the CMD UART output.

config CMD_INPUT_TASK_STACK_SIZE
  int "Input task stack size (bytes)"
  default 16384 if HQ_PLATFORM_POSIX
  default 4096
  range 1024 65536

config CMD_INPUT_TASK_PRIORITY
  int "Input task priority"
  default 5
  range 1 25

config CMD_RX_BUFFER_SIZE
  int "CLI RX buffer size"
  default 256
  range 32 4096

config CMD_BUFFER_SIZE
  int "CLI command buffer size"
  default 256
  range 32 4096

config CMD_HISTORY_BUFFER_SIZE
  int "CLI history buffer size"
  default 512
  range 64 8192

config CMD_MAX_BINDING_COUNT
  int "CLI max binding count"
  default 32
  range 1 256

config CMD_ENABLE_AUTOCOMPLETE
  bool "Enable CLI autocomplete"
  default y

config CMD_INVITATION
  string "CLI invitation"
  default "hq> "

endmenu

menu "Mongoose"

config MONGOOSE_LOG_LEVEL
  int "Mongoose log level"
  default 2
  range 0 4
  help
    0 = MG_LL_NONE
    1 = MG_LL_ERROR
    2 = MG_LL_INFO
    3 = MG_LL_DEBUG
    4 = MG_LL_VERBOSE

endmenu
